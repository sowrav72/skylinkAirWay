# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get from: https://neon.tech → your project → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
# Direct URL needed for Prisma migrations on Neon (connection pooling bypass)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# CRITICAL: Generate a strong secret. Never use a default or public value.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MINIMUM_64_CHARS"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of your exact deployed frontend URLs (no trailing slash)
# Example: ALLOWED_ORIGINS=https://skywings-passenger.onrender.com,https://skywings-admin.onrender.com
ALLOWED_ORIGINS="https://your-passenger-app.onrender.com,https://your-admin-app.onrender.com"

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is set automatically by Render — do NOT set it manually
