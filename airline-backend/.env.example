# ─── Database ────────────────────────────────────────────────
# Get this from your Neon dashboard → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/airline_db?sslmode=require

# ─── JWT ─────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=your_very_long_random_secret_here_change_this
JWT_EXPIRES_IN=24h

# ─── CORS ────────────────────────────────────────────────────
# Set to your deployed frontend URL (no trailing slash)
# Use * for development / open access
CORS_ORIGIN=https://your-frontend.vercel.app

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=production
# PORT is set automatically by Render — do not set here
